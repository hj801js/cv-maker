{
  "name": "cv-maker",
  "private": true,
  "version": "0.1.0",
  "description": "Offline desktop CV maker (Electron + Vue 3) — bilingual (KO/EN), per-profile JSON data.",
  "author": "Heejin Kim",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "gen-icon": "node scripts/gen-icon.mjs",
    "pack": "vite build && electron-builder --dir",
    "dist": "vite build && electron-builder",
    "smoke": "node scripts/smoke.mjs"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.1",
    "vite": "^6.0.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.9",
    "vue": "^3.5.13"
  },
  "build": {
    "appId": "com.heejinkim.cvmaker",
    "productName": "CV Maker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**"
    ],
    "extraResources": [
      {
        "from": "electron/resources",
        "to": "resources"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office"
    }
  }
}
